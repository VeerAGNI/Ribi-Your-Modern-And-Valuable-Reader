# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ADMIN AUTO-LOGIN (optional — for admin device bypass)
# Set these to your Firebase email/password credentials.
# Once signed in on a device, Firebase persists the session automatically.
# To trigger admin login: click the Ribi logo 5 times fast on the login screen.
VITE_ADMIN_EMAIL="admin@example.com"
VITE_ADMIN_PASSWORD="your_admin_password"
